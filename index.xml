[11:51, 2/4/2023] Nicola Sebastianutto: <!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8">
    <title>Convertitore di stringhe in equazioni</title>
  </head>
  <body>
    <h1>Convertitore di stringhe in equazioni</h1>
    <p>Inserisci una stringa:</p>
    <input type="text" id="stringa" name="stringa">
    <button onclick="converti()">Converti</button>
    <p id="equazione"></p>
    
    <script>
      function converti() {
        const stringaInput = document.getElementById("stringa").value;
        let equazione = "";
        for (let i = 0; i < stringaInput.length; i++) {
          let char = stringaInput[i];
          if (char.toUpperCase() === "A") {
            equazione += "+";
          } else if (char.toUpperCase() === "E") {
            equazione += "-";
          } else if (char.toUpperCase() === "I") {
            equazione += "*";
          } else if (char.toUpperCase() === "O") {
            equazione += "/";
          } else if (char.toUpperCase() === "U") {
            equazione += "^";
          } else if (char.toUpperCase() === "B") {
            equazione += "1";
          } else if (char.toUpperCase() === "C") {
            equazione += "2";
          } else if (char.toUpperCase() === "D") {
            equazione += "3";
          } else if (char.toUpperCase() === "F") {
            equazione += "4";
          } else if (char.toUpperCase() === "G") {
            equazione += "5";
          } else if (char.toUpperCase() === "H") {
            equazione += "6";
          } else if (char.toUpperCase() === "J") {
            equazione += "7";
          } else if (char.toUpperCase() === "K") {
            equazione += "8";
          } else if (char.toUpperCase() === "L") {
            equazione += "9";
          } else if (char.toUpperCase() === "M") {
            equazione += "10";
          } else if (char.toUpperCase() === "N") {
            equazione += "15";
          } else if (char.toUpperCase() === "P") {
            equazione += "20";
          } else if (char.toUpperCase() === "Q") {
            equazione += "25";
          } else if (char.toUpperCase() === "R") {
            equazione += "30";
          } else if (char.toUpperCase() === "S") {
            equazione += "35";
          } else if (char.toUpperCase() === "T") {
            equazione += "40";
          } else if (char.toUpperCase() === "V") {
            equazione += "45";
          } else if (char.toUpperCase() === "W") {
            equazione += "50";
          } else if (char.toUpperCase() === "X") {
            equazione += "100";
          } else if (char.toUpperCase() === "Y") {
            equazione += "200";
          } else if (char.toUpperCase() === "Z") {
            equazione += "500";
          } else if (char === " ") {
            equazione += ",";
          } else {
            equazione += "0";
          }
        }
        document.getElementById("equazione").innerText = equazione;
      }
    </script>
  </body
